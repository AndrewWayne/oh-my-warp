# Claude Code per-user overrides (do not commit)
.claude/settings.local.json
.claude/scheduled_tasks.json
.claude/scheduled_tasks.lock

# OS / editor noise
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Build artifacts (placeholders for when crates land)
target/
node_modules/
dist/
build/
*.tsbuildinfo
# tsc -b emits .d.ts/.js next to .ts config files (vite.config.*, tailwind.config.*, etc.).
apps/web-controller/vite.config.d.ts
apps/web-controller/vite.config.js
apps/web-controller/tailwind.config.d.ts
apps/web-controller/tailwind.config.js

# TRD coordination state (per-run, not committed)
.tmp/

# Local secrets / env (keys belong in OS keychain, not in env files)
.env
.env.local

# Logs
*.log
