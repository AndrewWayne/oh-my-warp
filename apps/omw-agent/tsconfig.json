{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "lib": ["ES2022"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@pi-agent-core": ["./vendor/pi-agent-core/index.ts"],
      "@pi-agent-core/*": ["./vendor/pi-agent-core/*"]
    }
  },
  "include": ["src/**/*", "test/**/*", "vendor/pi-agent-core/**/*"]
}
